APP_ENV=development
APP_NAME=Platform Core
DATABASE_URL=postgresql+psycopg2://platform:platform@postgres:5432/platform
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

STORAGE_PROVIDER=minio
STORAGE_BUCKET=platform
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=platform
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
WEBDAV_BASE_URL=https://webdav.example.com
WEBDAV_USERNAME=change-me
WEBDAV_PASSWORD=change-me

OPENCLAW_BASE_URL=http://openclaw:8080
OPENCLAW_ENABLED=false

REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
FLOWISE_URL=http://flowise:3000
SHARED_CONTEXT_INDEX_PROVIDER=qdrant
ORCHESTRATION_MAX_STEPS=12
APPROVAL_TTL_MINUTES=1440
TENANT_ENFORCE_ISOLATION=true

SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeMe123!
